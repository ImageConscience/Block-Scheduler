# Required for Prisma (PostgreSQL). Railway injects this when Postgres is linked.
# For local dev: use a local Postgres or a free hosted DB (e.g. Neon, Supabase).
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Shopify app (from Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.up.railway.app
SCOPES=read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,write_products,unauthenticated_read_metaobjects,read_files,write_files,read_content,write_content

# Billing
BILLING_PLAN_NAME=Block Scheduler Pro
BILLING_PRICE=14.99
BILLING_CURRENCY=USD
BILLING_TRIAL_DAYS=7
BILLING_TEST=true

# Production
NODE_ENV=production
